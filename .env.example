APP_ENV=development
APP_CONFIG_FILE=config/defaults.yaml
APP_SECRET_KEY=replace-with-long-random-secret
APP_BASE_URL=http://localhost:8000
APP_PUBLIC_WEBHOOK_BASE_URL=https://your-public-url.example
APP_LOG_PATH=var/log/companion.log
APP_MEDIA_ROOT=var/media
APP_PROMPT_TEMPLATE_ROOT=app/prompts

DATABASE_URL=postgresql+asyncpg://companion:companion@postgres:5432/companion
DATABASE_SYNC_URL=postgresql+psycopg://companion:companion@postgres:5432/companion

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_VOICE_CALLBACK_URL=
TWILIO_VOICE_STATUS_CALLBACK_URL=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts

ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_SESSION_COOKIE_NAME=companion_admin_session
ADMIN_SESSION_MAX_AGE_SECONDS=86400

ALERT_WEBHOOK_URL=
