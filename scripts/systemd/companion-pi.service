[Unit]
Description=Companion Pi FastAPI service
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/companion-pi
Environment=APP_CONFIG_FILE=/opt/companion-pi/config/defaults.yaml
ExecStart=/root/.local/bin/uv run uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
